{
  "name": "@defituna/client-rs",
  "description": "Rust client to interact with DefiTuna's on-chain program.",
  "version": "1.0.0",
  "private": false,
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "codama": "node ./codama.js",
    "build": "pnpm codama"
  },
  "devDependencies": {
    "@codama/nodes": "^1.2.8",
    "@codama/renderers-rust": "^1.0.16",
    "@codama/visitors-core": "^1.2.8",
    "@codama/nodes-from-anchor": "^1.1.8",
    "@codama/renderers": "^1.0.16",
    "codama": "^1.2.8",
    "@defituna/eslint-config": "^0.4.0",
    "@defituna/prettier-config": "^0.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.3.5",
    "typescript": "5.5.4",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "dependencies": {}
}